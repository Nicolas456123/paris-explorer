{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "python-server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    },
    {
      "name": "npx-serve",
      "runtimeExecutable": "npx.cmd",
